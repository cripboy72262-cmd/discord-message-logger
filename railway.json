{
  "$schema": "https://railway.app/railway.schema.json",
  "build": { "builder": "NIXPACKS" },
  "deploy": {
    "startCommand": "npm start",
    "restartPolicyMaxRetries": 10,
    "healthchecks": {
      "httpPath": "/health",
      "interval": 30,
      "timeout": 10
    }
  },
  "volumes": [{ "name": "data", "mountPath": "/app/data" }]
}
