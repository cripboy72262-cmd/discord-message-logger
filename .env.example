# Environment variables for .env file
# Copy this to .env and fill in your values

# Discord User Account Token (REQUIRED)
# Get from Discord browser console:
# 1. Open Discord in browser
# 2. Press F12 → Application → Local Storage → https://discord.com
# 3. Find 'token' key and copy the value (remove quotes)
USER_TOKEN=your_user_token_here

# Database file path
# Local: ./messages.db
# Railway: /app/data/messages.db (auto-set by config.js)
DB_PATH=./messages.db

# Node environment
NODE_ENV=development
